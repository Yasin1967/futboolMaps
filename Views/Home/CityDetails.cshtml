@model FOOTBALMAPSV2.Models.City
@{
    ViewData["Title"] = Model.Name + " - Şehir Detayları";
}

<div class="city-details-container fade-in">
    <!-- Hero Section -->
    <div class="city-hero mb-5">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a asp-action="Index">Harita</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
                </ol>
            </nav>
            <h1 class="display-3 fw-bold">@Model.Name</h1>
            <p class="lead opacity-75">@Model.History</p>
        </div>
    </div>

    <div class="container pb-5">
        <div class="row g-4">
            <!-- Left Column: Details -->
            <div class="col-lg-8">
                <!-- Info Grid -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="info-card h-100">
                            <div class="info-card-icon">
                                <i class="bi bi-book-fill"></i>
                            </div>
                            <h5>Tarihçe</h5>
                            <p>@Model.History</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-card h-100">
                            <div class="info-card-icon">
                                <i class="bi bi-palette-fill"></i>
                            </div>
                            <h5>Kültür & Sanat</h5>
                            <p>@Model.Culture</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-card h-100">
                            <div class="info-card-icon">
                                <i class="bi bi-cup-hot-fill"></i>
                            </div>
                            <h5>Yerel Lezzetler</h5>
                            <p>@Model.LocalFood</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-card h-100">
                            <div class="info-card-icon">
                                <i class="bi bi-tree-fill"></i>
                            </div>
                            <h5>Doğal Güzellikler</h5>
                            <p>@Model.NaturalResources</p>
                        </div>
                    </div>
                </div>

                <!-- Teams Section -->
                <div class="teams-section">
                    <div class="d-flex align-items-center mb-4">
                        <div class="section-badge me-3">
                            <i class="bi bi-trophy-fill"></i>
                        </div>
                        <h3 class="mb-0">Profesyonel Futbol Takımları</h3>
                    </div>
                    
                    <div class="row g-3">
                        @if (Model.Teams != null && Model.Teams.Any())
                        {
                            foreach (var team in Model.Teams)
                            {
                                <div class="col-md-6">
                                    <a asp-action="TeamDetails" asp-route-id="@team.Id" class="text-decoration-none text-white">
                                        <div class="detailed-team-card team-card-clickable">
                                            <div class="team-logo-container">
                                                <img src="@team.LogoUrl" alt="@team.Name Logo" class="img-fluid" 
                                                     onerror="this.src='https://via.placeholder.com/100?text=Logo'"/>
                                            </div>
                                            <div class="team-info">
                                                <h4>@team.Name</h4>
                                                <div class="team-meta">
                                                    <span class="badge bg-primary text-white">Kuruluş: @team.FoundationYear</span>
                                                    <span class="badge bg-secondary">@Model.Name</span>
                                                </div>
                                                <p class="mt-2 text-muted small mb-0">Detayları görmek için tıklayın...</p>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12 py-5 text-center bg-dark rounded-3 opacity-50">
                                <i class="bi bi-info-circle display-4 mb-3"></i>
                                <p>Bu şehir için henüz kayıtlı futbol takımı bulunmamaktadır.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column: Stats & Meta -->
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 100px; z-index: 10;">
                    <div class="stats-card mb-4">
                        <div class="stats-header">
                            <i class="bi bi-bar-chart-fill me-2"></i> Şehir İstatistikleri
                        </div>
                        <div class="stats-body">
                            <div class="stat-item">
                                <span class="label">Taraftar Desteği</span>
                                <div class="progress mb-2" style="height: 10px; background: rgba(255,255,255,0.1);">
                                    <div class="progress-bar bg-info" role="progressbar" style="width: @(Model.SupportCount > 100 ? 100 : Model.SupportCount)%" aria-valuenow="@Model.SupportCount" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <span class="value">@Model.SupportCount Puan</span>
                            </div>
                            <hr class="opacity-10" />
                            <div class="stat-item d-flex justify-content-between align-items-center">
                                <span class="label text-muted">Takım Sayısı</span>
                                <span class="value h5 mb-0">@(Model.Teams?.Count ?? 0)</span>
                            </div>
                        </div>
                    </div>

                    <div class="cta-card">
                        <h5>Farklı bir şehre mi bakmak istiyorsunuz?</h5>
                        <p class="small text-muted mb-4">Türkiye'nin futbol haritasını keşfetmeye devam edin.</p>
                        <a asp-action="Index" class="btn btn-primary w-100 py-2">
                            <i class="bi bi-map-fill me-2"></i> Haritaya Dön
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-color: #6366f1;
        --secondary-color: #4f46e5;
        --bg-dark: #0f172a;
        --card-bg: rgba(30, 41, 59, 0.7);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    .city-details-container {
        color: #f1f5f9;
        min-height: 100vh;
        background: radial-gradient(circle at top right, #1e1b4b, #0f172a);
    }

    .city-hero {
        position: relative;
        height: 400px;
        background: url('https://images.unsplash.com/photo-1541432901042-26114ec24197?q=80&w=2000&auto=format&fit=crop') center center;
        background-size: cover;
        display: flex;
        align-items: flex-end;
        padding-bottom: 3rem;
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(0deg, #0f172a 0%, rgba(15, 23, 42, 0.4) 100%);
    }

    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
        padding: 0 1.5rem;
    }

    .breadcrumb-item a {
        color: var(--primary-color);
        text-decoration: none;
    }

    .breadcrumb-item.active {
        color: #94a3b8;
    }

    .info-card {
        background: var(--card-bg);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(12px);
        padding: 2rem;
        border-radius: 1.5rem;
        transition: transform 0.3s ease, border-color 0.3s ease;
    }

    .info-card:hover {
        transform: translateY(-5px);
        border-color: var(--primary-color);
    }

    .info-card-icon {
        width: 48px;
        height: 48px;
        background: rgba(99, 102, 241, 0.2);
        color: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .section-badge {
        width: 40px;
        height: 40px;
        background: #f59e0b;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-size: 1.25rem;
    }

    .detailed-team-card {
        background: var(--card-bg);
        border: 1px solid var(--glass-border);
        padding: 1.5rem;
        border-radius: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .team-card-clickable:hover {
        background: rgba(99, 102, 241, 0.15);
        border-color: var(--primary-color);
        transform: scale(1.02);
        box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
    }

    .team-logo-container {
        width: 80px;
        height: 80px;
        background: white;
        padding: 10px;
        border-radius: 15px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .team-info h4 {
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .stats-card, .cta-card {
        background: var(--card-bg);
        border: 1px solid var(--glass-border);
        border-radius: 1.5rem;
        overflow: hidden;
    }

    .stats-header {
        background: rgba(255, 255, 255, 0.05);
        padding: 1rem 1.5rem;
        font-weight: 600;
        border-bottom: 1px solid var(--glass-border);
    }

    .stats-body {
        padding: 1.5rem;
    }

    .cta-card {
        padding: 1.5rem;
        text-align: center;
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(79, 70, 229, 0.2) 100%);
    }

    .fade-in {
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
