@model FOOTBALMAPSV2.Models.Team

@{
    ViewData["Title"] = "Takımı Düzenle";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <h5 class="card-title fw-bold mb-4">Takım Bilgilerini Güncelle</h5>
                <form asp-action="EditTeam" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="LogoUrl" />

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label fw-600">Takım Adı</label>
                            <input asp-for="Name" class="form-control rounded-pill" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FoundationYear" class="form-label fw-600">Kuruluş Yılı</label>
                            <input asp-for="FoundationYear" class="form-control rounded-pill" />
                            <span asp-validation-for="FoundationYear" class="text-danger small"></span>
                        </div>
                        <div class="col-12 d-flex align-items-center gap-3">
                            @if (!string.IsNullOrEmpty(Model?.LogoUrl))
                            {
                                <img src="@Model.LogoUrl" alt="Logo" height="50" class="rounded border p-1" />
                            }
                            <div class="flex-grow-1">
                                <label for="logoFile" class="form-label fw-600">Yeni Logo Yükle</label>
                                <input type="file" name="logoFile" id="logoFile" class="form-control rounded-pill" accept="image/*" />
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="History" class="form-label fw-600">Takım Tarihçesi</label>
                            <textarea asp-for="History" class="form-control rounded-3" rows="4"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Achievements" class="form-label fw-600">Başarılar</label>
                            <textarea asp-for="Achievements" class="form-control rounded-3" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CityId" class="form-label fw-600">Şehir</label>
                            <select asp-for="CityId" class="form-select rounded-pill" asp-items="@(new SelectList(ViewBag.Cities, "Id", "Name"))">
                            </select>
                            <span asp-validation-for="CityId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LeagueId" class="form-label fw-600">Lig</label>
                            <select asp-for="LeagueId" class="form-select rounded-pill" asp-items="@(new SelectList(ViewBag.Leagues, "Id", "Name"))">
                            </select>
                            <span asp-validation-for="LeagueId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-5">Güncelle</button>
                        <a asp-action="Teams" class="btn btn-outline-secondary rounded-pill px-4">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
