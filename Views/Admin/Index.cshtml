@model FOOTBALMAPSV2.Controllers.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="row g-4">
        <!-- Stats Cards -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 stats-card city-gradient text-white">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="icon-wrapper me-4 p-3 bg-white bg-opacity-25 rounded-circle">
                        <i class="bi bi-geo-alt fs-2"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-white text-opacity-75">Toplam Şehir</h6>
                        <h2 class="card-title mb-0 fw-bold">@Model.CityCount</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 stats-card team-gradient text-white">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="icon-wrapper me-4 p-3 bg-white bg-opacity-25 rounded-circle">
                        <i class="bi bi-shield-shaded fs-2"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-white text-opacity-75">Toplam Takım</h6>
                        <h2 class="card-title mb-0 fw-bold">@Model.TeamCount</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 stats-card league-gradient text-white">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="icon-wrapper me-4 p-3 bg-white bg-opacity-25 rounded-circle">
                        <i class="bi bi-trophy fs-2"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-white text-opacity-75">Toplam Lig</h6>
                        <h2 class="card-title mb-0 fw-bold">@Model.LeagueCount</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-5">
        <div class="col-12">
            <h4 class="mb-4 fw-bold text-dark">Hızlı İşlemler</h4>
            <div class="d-flex flex-wrap gap-3">
                <a asp-action="Cities" class="btn btn-outline-primary rounded-pill px-4 py-2">
                    <i class="bi bi-list me-2"></i> Şehirleri Yönet
                </a>
                <a asp-action="Teams" class="btn btn-outline-success rounded-pill px-4 py-2">
                    <i class="bi bi-list-check me-2"></i> Takımları Yönet
                </a>
                <a asp-action="Leagues" class="btn btn-outline-info rounded-pill px-4 py-2">
                    <i class="bi bi-trophy-fill me-2"></i> Ligleri Yönet
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .city-gradient { background: linear-gradient(45deg, #4e54c8, #8f94fb); }
    .team-gradient { background: linear-gradient(45deg, #11998e, #38ef7d); }
    .league-gradient { background: linear-gradient(45deg, #f2994a, #f2c94c); }
    
    .stats-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .stats-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
